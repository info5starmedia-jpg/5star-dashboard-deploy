generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  role        String   @default("user") // "user" | "admin"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  targetEmail String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model Subscription {
  id                   String   @id @default(cuid())
  userEmail            String
  stripeCustomerId     String
  stripeSubscriptionId String   @unique
  priceId              String
  status               String
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userEmail])
  @@index([stripeCustomerId])
  @@index([status])
}

model StripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())

  @@index([type])
}

model InventoryItem {
  id         String   @id @default(cuid())
  name       String
  sku        String   @unique
  quantity   Int
  priceCents Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([name])
}
